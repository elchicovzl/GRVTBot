# GRVT Grid — self-host environment.
#
# Copy this file to .env and fill in. NEVER commit .env to git.
# (It's covered by .gitignore.)
#
# ─── GRVT credentials ───────────────────────────────────────────────────
# Generate from your GRVT account UI: https://grvt.io
# IMPORTANT: register through the referral link the project shares with the
# community. Self-hosting via this repo requires you to use the referral link.
GRVT_API_KEY=
GRVT_API_SECRET=0x...
GRVT_TRADING_ACCOUNT_ID=
GRVT_TRADING_ADDRESS=0x...

# Optional: separate funding (vault) account credentials
GRVT_FUNDING_API_KEY=
GRVT_FUNDING_API_SECRET=
GRVT_FUNDING_WALLET_ADDRESS=

# ─── Dashboard ─────────────────────────────────────────────────────────
# 32+ char random hex. Generate with:  openssl rand -hex 32
DASHBOARD_API_KEY=

# Legacy basic auth for the v1 dashboard (still mounted at /).
# Remove these once you've migrated fully to the v2 dashboard at /dashboard/.
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me

# Bind port on the host. With caddy, you can leave this and only expose 80/443.
BOT_PORT=3848

# ─── Notifier (optional) ───────────────────────────────────────────────
# Get TELEGRAM_BOT_TOKEN from @BotFather, then send any message to your bot
# and grab your chat id from
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_DRAWDOWN_PCT=15
NOTIFY_FILL_BATCH=5
DAILY_SUMMARY_HOUR_UTC=0

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
